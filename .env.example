APP_MODE=demo
APP_NAME=Kavach Saathi
API_PREFIX=/v1
FRONTEND_ORIGIN=http://localhost:3000
DATA_DIR=data/seed
ASSET_DIR=assets/mock

# Postgres
DATABASE_URL=postgresql+psycopg://kavach:kavach@localhost:5432/kavach_saathi

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (JWT)
JWT_SECRET=change-me-in-production
